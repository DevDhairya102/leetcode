import java.util.*;
public class hello{
    public static void main(String args[]){
        Scanner sc = new Scanner(System.in);
        System.out.println("Enter rows number:");
        int n = sc.nextInt();

        for(int i =0;i<n;i++){
            int val = 1;
            for(int j = 0;j<=i;j++){
                if(j>0)System.out.print(" ");
                System.out.print(val);
                val= val*(i-j)/(j+1);    
        }
        System.out.println("");
    }
}
}
