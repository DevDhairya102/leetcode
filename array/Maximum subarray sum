public class Max {
  public static int sequence(int[] arr) {
    int maxsum = 0;
    int currsum = 0;
    for(int i = 0;i<arr.length;i++){
      currsum+=arr[i];
      if(maxsum<currsum){
        maxsum = currsum;
      }
      if(currsum<0){
        currsum=0;
      }
    }
    return maxsum;
  }
}
