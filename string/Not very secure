public class SecureTester{
  
  public static boolean alphanumeric(String s){
    if(s.length()==0){
      return false;
    }
    for(int i = 0;i<s.length();i++){
      char ch = s.charAt(i);
      if(!((ch >= 'A' && ch <= 'Z') ||
       (ch >= 'a' && ch <= 'z') ||
       (ch >= '0' && ch <= '9'))){
        return false;
      }
      
  }
    return true;
  }

}
