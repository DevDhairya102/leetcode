import java.util.HashMap;

public class HexToRGB {
  
  public static HashMap<String, Integer> hexStringToRGB(String hex) {
    
    HashMap<String,Integer>map = new HashMap<>();
    map.put("r",Integer.parseInt(hex.substring(1,3),16));
    map.put("g",Integer.parseInt(hex.substring(3,5),16));
    map.put("b",Integer.parseInt(hex.substring(5,7),16));
    
    return map;
  }
  
}
