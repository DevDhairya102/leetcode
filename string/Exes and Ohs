public class XO {
  
  public static boolean getXO (String str) {
    
    str = str.toLowerCase();
    int x = 0;
    int o = 0;
    for(int i = 0;i<str.length();i++){
      char ch = str.charAt(i);
      
      if(ch=='x'){
        x++;
      }
      else if(ch=='o'){
        o++;
      }
    }
    return x==o;
  }
}
